	"license": "MIT",
	"author": {
		"name": "AUTHOR_NAME",
		"email": "AUTHOR_EMAIL"
	},
	"engines": {
		"node": ">=18.10"
	},
	"packageManager": "npm@10.8.2",
	"main": "index.js",
	"scripts": {
		"build": "n8n-node build",
		"dev": "n8n-node dev",
		"lint": "n8n-node lint",
		"lint:fix": "n8n-node lint --fix",
		"merge:api": "npx openapi-merge-cli --config ./openapi.config.json",
		"test": "WEBHOOK_URL=https://localhost:5678 jest --config jest.config.js",
