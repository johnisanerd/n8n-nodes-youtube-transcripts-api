			"dist/credentials/ApifyOAuth2Api.credentials.js"
		],
		"nodes": [
			"dist/nodes/ApifyYoutubeTranscripts/ApifyYoutubeTranscripts.node.js"
		]
	},
	"peerDependencies": {
		"n8n-workflow": "*"
	},
	"devDependencies": {
		"@n8n/node-cli": "0.32.1",
